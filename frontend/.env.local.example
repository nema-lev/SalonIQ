# URL на backend (вътрешен — от server-side Next.js)
BACKEND_URL=http://localhost:3001

# Вътрешен ключ за SSR заявки (трябва да съвпада с backend)
INTERNAL_API_KEY=same_as_backend

# Публичен домейн на платформата (client-side)
NEXT_PUBLIC_APP_DOMAIN=saloniq.bg

# Default tenant за localhost / Vercel preview / временни домейни.
# Ползва се само когато host-ът не съвпада с custom domain или known subdomain.
NEXT_PUBLIC_DEFAULT_TENANT_SLUG=demo-business

# Server-side fallback за SSR в Next layout-а.
# Обикновено е същият slug като NEXT_PUBLIC_DEFAULT_TENANT_SLUG.
DEFAULT_TENANT_SLUG=demo-business
