# ─── Database ────────────────────────────────────────────────────
DATABASE_URL="postgresql://saloniq_user:STRONG_PASSWORD@localhost:5432/saloniq_db?schema=public"

# ─── Redis (за BullMQ queue) ──────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT ──────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_THIS_TO_A_VERY_LONG_RANDOM_STRING_AT_LEAST_64_CHARS
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=ANOTHER_VERY_LONG_RANDOM_STRING
JWT_REFRESH_EXPIRES_IN=30d

# ─── App ──────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
APP_DOMAIN=saloniq.bg
FRONTEND_URL=https://saloniq.bg
CORS_ORIGINS=https://saloniq.bg,https://*.saloniq.bg
INTERNAL_API_KEY=CHANGE_THIS_TO_A_RANDOM_INTERNAL_API_KEY

# ─── Telegram (тест фаза) ─────────────────────────────────────────
# Всеки tenant има свой bot token в базата данни
# Това е за системни известявания (грешки, нови регистрации и т.н.)
SYSTEM_TELEGRAM_BOT_TOKEN=
SYSTEM_TELEGRAM_CHAT_ID=

# ─── SMS (smsapi.bg) — за бъдеще ─────────────────────────────────
# SMSAPI_TOKEN=
# SMSAPI_SENDER=SalonIQ

# ─── Email ────────────────────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=
EMAIL_FROM=noreply@saloniq.bg

# ─── Rate Limiting ────────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=30
