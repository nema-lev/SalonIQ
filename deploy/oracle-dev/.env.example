BACKEND_HOST=saloniq.duckdns.org

POSTGRES_DB=saloniq_db
POSTGRES_USER=saloniq_user
POSTGRES_PASSWORD=change_this_postgres_password

JWT_SECRET=change_this_to_a_long_random_secret_at_least_64_chars
JWT_REFRESH_SECRET=change_this_to_another_long_random_secret_at_least_64_chars
INTERNAL_API_KEY=change_this_to_a_random_internal_api_key

# Tenant/app domain used by SalonIQ tenant resolution.
APP_DOMAIN=saloniq.bg

# Public frontend origin(s) allowed to call the backend.
FRONTEND_URL=https://your-vercel-project.vercel.app
CORS_ORIGINS=https://your-vercel-project.vercel.app,https://*.vercel.app

# Optional preview/dev fallback when the frontend host is not under APP_DOMAIN.
# DEFAULT_TENANT_SLUG=demo-business
